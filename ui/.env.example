# Path overrides for the Next.js console.
# Copy to .env.local and edit if your environment differs from the defaults.

# Absolute path to the python interpreter that has the pipeline deps installed.
# If you used a venv at game_asset_video_pipeline/.venv, point to its python.exe.
# Defaults to "python.exe" (Windows) or "python3" (Unix) on PATH.
# PYTHON_BIN=F:/AI/UI-Animation-Train/game_asset_video_pipeline/.venv/Scripts/python.exe

# Absolute path to the game_asset_video_pipeline directory.
# Defaults to ../game_asset_video_pipeline relative to the ui/ folder.
# PIPELINE_DIR=F:/AI/UI-Animation-Train/game_asset_video_pipeline

# Optional: pin a different LM Studio endpoint exposed to the dashboard.
# Defaults to http://localhost:1234/v1
# LMSTUDIO_BASE_URL=http://localhost:1234/v1
